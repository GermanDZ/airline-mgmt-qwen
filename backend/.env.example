# Airline Management System — Environment Variables (copy to .env)
# DO NOT commit your actual .env file.

# Application
DEBUG=false
LOG_LEVEL=INFO

# Database — PostgreSQL 15+
DATABASE_URL=postgresql+asyncpg://ams:ams_password@localhost:5432/ams

# Redis — Cache & Pub/Sub
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
SECRET_KEY=change-me-to-a-random-32-byte-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
